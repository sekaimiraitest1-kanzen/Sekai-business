# Trisha — environment variable template for Vercel.
#
# Copy this to web/.env.local for local dev (filled), and set the same keys in
# Vercel dashboard → Project → Settings → Environment Variables for production
# and preview scopes. Service-role keys MUST be marked "Sensitive" in Vercel.
#
# Plug-in moment: when domain arrives, ONLY NEXT_PUBLIC_SITE_URL changes.
# Everything else is stable.

# ── Supabase ──────────────────────────────────────────────────────────────
# From Supabase dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-jwt>
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>      # SENSITIVE — never expose to client
SUPABASE_DB_PASSWORD=<postgres-password>          # used by GitHub Actions backup workflow

# ── Resend (transactional email) ──────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_<key>
# Pre-launch keep "onboarding@resend.dev" — swap to noreply@<domain> after
# Resend domain verification (DKIM/SPF/DMARC) on the production domain.
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── Site URL ──────────────────────────────────────────────────────────────
# Pre-launch: leave the Vercel preview URL (auto-assigned, e.g.
# trisha.vercel.app). Day-of-launch: set this to https://<final-domain>.
# Read by sitemap.xml, robots.txt, llms.txt, and every JSON-LD @id/url.
NEXT_PUBLIC_SITE_URL=https://<your-vercel-or-final-domain>

# ── Salon slug (multi-tenant scaffold) ────────────────────────────────────
# Currently single-tenant; this picks which row in `salons` is rendered as
# the public site. Stays "trisa" for V1.
NEXT_PUBLIC_DEFAULT_SALON_SLUG=trisa

# ── Google Business Profile (optional) ────────────────────────────────────
# Public URL of the claimed GBP listing. Surfaces as a sameAs[] entry in
# the LocalBusiness JSON-LD on the homepage. Leave unset until claimed.
# NEXT_PUBLIC_GBP_URL=https://maps.google.com/?cid=<id>
